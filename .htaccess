# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/path/to/your/app"
PassengerBaseURI "/"
PassengerPython "/path/to/your/virtualenv/bin/python"

# Restrict access to backend and database files
<FilesMatch "\.(py|db|sqlite3|env)$">
    Require all denied
</FilesMatch>
# Also explicitly deny access to requirements.txt and configurations if needed
<FilesMatch "^(requirements\.txt|config\.py|todos\.db)$">
    Require all denied
</FilesMatch>

# (Removed the RewriteCond / RewriteRule block as Passenger natively routes requests)
